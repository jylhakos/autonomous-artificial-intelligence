# Environment Configuration for LangChain and LangSmith

# =============================================================================
# LangSmith Configuration (for observability and evaluation)
# =============================================================================

# Enable LangSmith tracing (set to "true" to enable)
LANGCHAIN_TRACING_V2=true

# LangSmith API endpoint
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# LangSmith API Key (get from https://smith.langchain.com/)
# Create a free account and generate an API key in Settings > API Keys
LANGCHAIN_API_KEY=your_langsmith_api_key_here

# LangSmith Project Name (traces will be organized under this project)
LANGCHAIN_PROJECT=agent-evaluation-demo

# Alternative: Some documentation may use LANGSMITH_API_KEY
# LANGSMITH_API_KEY=your_langsmith_api_key_here

# =============================================================================
# LLM Provider API Keys
# =============================================================================

# Anthropic API Key (for Claude models)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (optional, if using OpenAI models)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# LangSmith Organization (Optional - for advanced usage)
# =============================================================================

# Organization ID (for API-based organization management)
# LANGSMITH_ORGANIZATION_ID=your_org_id_here

# =============================================================================
# Langfuse Configuration (Optional - alternative to LangSmith)
# =============================================================================

# Langfuse Public Key
# LANGFUSE_PUBLIC_KEY=your_langfuse_public_key

# Langfuse Secret Key
# LANGFUSE_SECRET_KEY=your_langfuse_secret_key

# Langfuse Host (default: https://cloud.langfuse.com)
# LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# Application Settings
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable verbose agent output
AGENT_VERBOSE=true
